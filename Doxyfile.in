# HoloPhysics Lab 2 — Doxygen Configuration
DOXYFILE_ENCODING = UTF-8
PROJECT_NAME = "HoloPhysics Lab 2"
PROJECT_NUMBER = 3.6.0
PROJECT_BRIEF = "Научная физическая песочница с AR/Hand Tracking"
PROJECT_LOGO = assets/logo.png
OUTPUT_DIRECTORY = docs/doxygen
INPUT = src README.md
RECURSIVE = YES
FILE_PATTERNS = *.h *.cpp *.hpp *.md
EXCLUDE = src/external
EXCLUDE_PATTERNS = */miniaudio.h */sol.hpp
EXTRACT_ALL = YES
EXTRACT_PRIVATE = NO
EXTRACT_STATIC = YES
WARN_IF_UNDOCUMENTED = YES
WARN_IF_DOC_ERROR = YES
INPUT_ENCODING = UTF-8
SOURCE_BROWSER = YES
INLINE_SOURCES = NO
STRIP_CODE_COMMENTS = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION = YES
REFERENCES_LINK_SOURCE = YES
USE_HTAGS = YES
VERBATIM_HEADERS = YES
GENERATE_TREEVIEW = YES
DISABLE_INDEX = NO
FULL_SIDEBAR = NO
HTML_OUTPUT = html
HTML_FILE_EXTENSION = .html
HTML_COLORSTYLE_HUE = 180
HTML_COLORSTYLE_SAT = 80
HTML_COLORSTYLE_GAMMA = 80
HTML_TIMESTAMP = YES
DOT_IMAGE_FORMAT = svg
DOT_PATH = /usr/bin/dot
INTERACTIVE_SVG = YES
CALL_GRAPH = YES
CALLER_GRAPH = YES
EXTRACT_ALL = YES
HAVE_DOT = YES
DOT_NUM_THREADS = 4
DOT_GRAPH_MAX_NODES = 50
MAX_DOT_GRAPH_DEPTH = 5
PREDEFINED = "HOLO_HAVE_OPENCV"
MACRO_EXPANSION = YES
SKIP_FUNCTION_MACROS = NO
CPP_CLI_SUPPORT = NO
SORT_MEMBER_DOCS = YES
SORT_BRIEF_DOCS = YES
SORT_GROUP_NAMES = YES
SORT_BY_SCOPE_NAME = YES
GENERATE_LATEX = NO
GENERATE_RTF = NO
GENERATE_MAN = NO
GENERATE_DOCBOOK = NO
GENERATE_AUTOGEN_DEF = NO
SEARCHENGINE = YES
SERVER_BASED_SEARCH = NO
EXTERNAL_SEARCH = NO
SEARCHDATA_FILE = searchdata.xml
